# PixelAcademy Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_PASSWORD=YourStrongPostgresPassword123!

# JWT Secret (must be at least 32 characters)
JWT_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

# API Settings
ASPNETCORE_ENVIRONMENT=Production
API_PORT=5000

# Frontend URLs (comma-separated for local, or configure in appsettings)
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# Redis
REDIS_PORT=6379

# File Upload
MAX_FILE_SIZE_MB=100

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_MINUTE=5
REGISTER_RATE_LIMIT_PER_5MIN=3
